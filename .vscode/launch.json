{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Dusklight (RelWithDebInfo)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-msvc-relwithdebinfo/dusklight.exe",
            "args": ["${workspaceFolder}/game.iso"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "CMake: Build (RelWithDebInfo)"
        },
        {
            "name": "Launch Dusklight (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-msvc-debug/dusklight.exe",
            "args": ["${workspaceFolder}/game.iso"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "CMake: Build (Debug)"
        }
    ]
}
