{
  // Ctrl+Shift+B runs the default build task ("CMake: Build (RelWithDebInfo)").
  // Each task sources vcvars64.bat so MSVC (cl.exe) is on PATH for Ninja.
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "cmd.exe",
      "args": ["/d", "/c"]
    }
  },
  "tasks": [
    {
      "label": "CMake: Configure (RelWithDebInfo)",
      "type": "shell",
      "command": "\"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" >nul && cmake --preset windows-msvc-relwithdebinfo",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "\"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" >nul && cmake --preset windows-msvc-debug",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build (RelWithDebInfo)",
      "type": "shell",
      "command": "\"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" >nul && cmake --build --preset windows-msvc-relwithdebinfo",
      "options": { "cwd": "${workspaceFolder}" },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "CMake: Build (Debug)",
      "type": "shell",
      "command": "\"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" >nul && cmake --build --preset windows-msvc-debug",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "CMake: Clean (RelWithDebInfo)",
      "type": "shell",
      "command": "\"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat\" >nul && cmake --build --preset windows-msvc-relwithdebinfo --target clean",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
